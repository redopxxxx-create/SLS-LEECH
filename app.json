{
  "name": "SLS-LEECH",
  "description": "Advanced Telegram Leech Bot",
  "logo": "https://telegra.ph/file/your-logo-link.jpg",
  "repository": "https://github.com/redopxxxx-create/SLS-LEECH",
  "keywords": ["telegram", "leech", "bot", "pyrogram"],
  "env": {
    "API_ID": {
      "description": "Get this from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Get this from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Get this from @BotFather",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "DATABASE_URL": {
      "description": "MongoDB URI for database",
      "required": true
    },
    "LOG_CHANNEL": {
      "description": "Log channel ID (starts with -100)",
      "required": true
    },
    "AUTH_CHATS": {
      "description": "Authorized chat IDs separated by space",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "eco"
    }
  }
}
